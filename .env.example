# DomTextil v2.0 - Configuration File
# Используйте этот файл для управления переменными окружения

# ============================================================================
# ENVIRONMENT
# ============================================================================
# Окружение: development, staging, production
NODE_ENV=development

# ============================================================================
# API CONFIGURATION
# ============================================================================
# API URL для получения списка товаров (Google Apps Script)
# Формат: https://script.google.com/macros/d/{SCRIPT_ID}/usercache
VITE_REACT_APP_PRODUCTS_API_URL=https://script.google.com/macros/d/YOUR_SCRIPT_ID_HERE/usercache

# API URL для отправки заказов
VITE_REACT_APP_ORDER_API_URL=https://script.google.com/macros/d/YOUR_SCRIPT_ID_HERE/usercache

# Главная страница (для перенаправления)
VITE_REACT_APP_HOME_PAGE_URL=https://example.com

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================
# Ключ хранилища для кэширования в localStorage
VITE_REACT_APP_CACHE_CART_KEY=domtextil_cart
VITE_REACT_APP_CACHE_PRODUCTS_KEY=domtextil_products_cache
VITE_REACT_APP_CACHE_TTL_MINUTES=10

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Включить Service Worker
VITE_REACT_APP_ENABLE_SERVICE_WORKER=true

# Включить продвинутое кэширование
VITE_REACT_APP_ENABLE_ADVANCED_CACHING=true

# Включить аналитику (Google Analytics, Yandex.Metrica и т.д.)
VITE_REACT_APP_ENABLE_ANALYTICS=true

# Google Analytics ID
VITE_REACT_APP_GOOGLE_ANALYTICS_ID=

# Яндекс.Метрика ID
VITE_REACT_APP_YANDEX_METRIKA_ID=

# ============================================================================
# PAYMENT & CHECKOUT
# ============================================================================
# Включить функцию оформления заказа
VITE_REACT_APP_ENABLE_CHECKOUT=true

# Минимальная сумма заказа (в рублях)
VITE_REACT_APP_MIN_ORDER_AMOUNT=0

# Валюта
VITE_REACT_APP_CURRENCY=RUB

# ============================================================================
# UI CONFIGURATION
# ============================================================================
# Количество товаров на странице
VITE_REACT_APP_ITEMS_PER_PAGE=12

# Включить фильтры по категориям
VITE_REACT_APP_ENABLE_FILTERS=true

# Включить сортировку товаров
VITE_REACT_APP_ENABLE_SORT=true

# ============================================================================
# BRANDING
# ============================================================================
# Название магазина
VITE_REACT_APP_STORE_NAME=DomTextil

# Логотип (URL)
VITE_REACT_APP_LOGO_URL=/assets/logo.png

# Тема цвет (hex)
VITE_REACT_APP_PRIMARY_COLOR=#2f6fed

# ============================================================================
# DEBUG & LOGGING
# ============================================================================
# Уровень логирования: debug, info, warn, error
LOG_LEVEL=info

# Включить verbose логирование
DEBUG=false

# Включить логирование Service Worker
DEBUG_SERVICE_WORKER=false

# Включить логирование кэша
DEBUG_CACHE=false

# ============================================================================
# SECURITY & COMPLIANCE
# ============================================================================
# Content Security Policy
VITE_REACT_APP_CSP_ENABLED=false

# CORS Origin (для продакшена)
VITE_REACT_APP_CORS_ORIGIN=*

# ============================================================================
# BUILD
# ============================================================================
# Путь для вывода (для build-инструментов)
BUILD_OUTPUT_DIR=dist

# Минификация JavaScript
MINIFY_JS=true

# Минификация CSS
MINIFY_CSS=true

# Генерировать Source Maps
GENERATE_SOURCE_MAPS=false
